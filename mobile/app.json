{
  "expo": {
    "name": "Payvio",
    "slug": "payvio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4f46e5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.payvio.app"
    },
    "android": {
      "package": "com.payvio.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#4f46e5",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      ["@stripe/stripe-react-native", { "merchantIdentifier": "merchant.com.payvio.app", "enableGooglePay": true }],
      "expo-web-browser"
    ]
  }
}
