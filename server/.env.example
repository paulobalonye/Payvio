# =============================================================
# Payvio Backend — Environment Variables
# Copy to .env and fill in real values
# =============================================================

# --- App ---
NODE_ENV=development
PORT=4000
APP_URL=https://payvio.com

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://payvio:payvio_dev_password@localhost:5432/payvio

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT ---
JWT_SECRET=change-this-to-a-64-char-random-string-in-production

# --- AWS SNS (SMS) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Stripe (Card Wallet Funding) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- YellowCard (FX Rates, Transfers, Multi-Currency Wallets) ---
YELLOWCARD_API_KEY=
YELLOWCARD_SECRET_KEY=
YELLOWCARD_BASE_URL=https://sandbox.yellowcard.io

# --- Flutterwave (Bank Verification, Nigerian Settlement) ---
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-...
FLUTTERWAVE_WEBHOOK_SECRET=

# --- Veriff (KYC Identity Verification) ---
VERIFF_API_KEY=
VERIFF_SHARED_SECRET=
VERIFF_BASE_URL=https://stationapi.veriff.com

# --- Resend (Transactional Email) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@payvio.com

# --- Referral ---
REFERRAL_REWARD_CENTS=500
